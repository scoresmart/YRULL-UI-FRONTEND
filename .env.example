# Yrull — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API (required for production)
VITE_API_BASE_URL=

# Mock mode — set to "true" to use mock data without a backend
VITE_USE_MOCK=true

# Facebook/Meta OAuth (required for Instagram & WhatsApp integrations)
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_CONFIG_ID=
VITE_FACEBOOK_OAUTH_SCOPES=public_profile

# Sentry error monitoring (optional)
VITE_SENTRY_DSN=
