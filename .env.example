# ─── Supabase (required for real login on production) ───────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# On Vercel: Settings → Environment Variables → add BOTH → Redeploy
#
# Prefer VITE_ names (required for most Vite apps). This project also accepts:
#   SUPABASE_URL  and  SUPABASE_ANON_KEY  (no VITE_ prefix) via vite.config.js
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Backend API (optional — OAuth, WhatsApp, etc.)
VITE_API_BASE_URL=

# Set to true only for local UI/dev without a Supabase project.
# Production MUST use false (or omit) when VITE_SUPABASE_* are set.
VITE_USE_MOCK=false
