# ─── Supabase (required for real login on production) ───────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# On Vercel: Settings → Environment Variables → add BOTH → Redeploy
#
# Prefer VITE_ names (required for most Vite apps). This project also accepts:
#   SUPABASE_URL  and  SUPABASE_ANON_KEY  (no VITE_ prefix) via vite.config.js
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Login page “Connect to Facebook” uses Supabase Auth (Authentication → Providers → Facebook).
# Add redirect URLs: http://localhost:5173/ and https://your-app.vercel.app/
#
# Backend API base URL (required to link Instagram to a workspace after sign-in — Integrations / Instagram page).
# Must be the origin where /oauth/instagram/authorize lives — NOT this frontend URL.
# Example: https://api.yrull.com  (also accepts API_BASE_URL without VITE_ via vite.config.js)
VITE_API_BASE_URL=https://your-api-server.com

# Set to true only for local UI/dev without a Supabase project.
# Production MUST use false (or omit) when VITE_SUPABASE_* are set.
VITE_USE_MOCK=false
